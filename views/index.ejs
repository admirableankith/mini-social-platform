<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Register</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>
<body class="bg-zinc-950 flex justify-center items-center min-h-screen">

<div class="bg-zinc-900 p-10 rounded-xl w-[450px] border border-zinc-700">

    <h1 class="text-white text-3xl font-semibold mb-8">
        Create Account
    </h1>

    <form action="/register" method="POST" class="space-y-4">

        <input
        type="text"
        name="name"
        placeholder="Name"
        class="w-full p-3 rounded-md bg-zinc-800 text-white">

        <input
        type="text"
        name="username"
        placeholder="Username"
        class="w-full p-3 rounded-md bg-zinc-800 text-white">

        <input
        type="number"
        name="age"
        placeholder="Age"
        class="w-full p-3 rounded-md bg-zinc-800 text-white">

        <input
        type="email"
        name="email"
        placeholder="Email"
        class="w-full p-3 rounded-md bg-zinc-800 text-white">

        <input
        type="password"
        name="password"
        placeholder="Password"
        class="w-full p-3 rounded-md bg-zinc-800 text-white">

        <button
        class="w-full bg-blue-500 hover:bg-blue-600 py-3 rounded-md text-white font-medium">

            Create Account

        </button>

    </form>

</div>

</body>
</html>