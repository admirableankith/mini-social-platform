<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen">
<div class="p-10">
    <div class="flex justify-end">
        <a href="/logout"
        class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-md font-medium">
            Logout
        </a>
    </div>
    <h1 class="text-4xl font-semibold mt-4">
        Hello, <%= user.name %> 👋
    </h1>
    <p class="text-zinc-400 mt-2">
        You can create a new post.
    </p>
    <form action="/post" method="POST" class="mt-8">
        <textarea
        name="content"
        placeholder="What's on your mind ?"
        class="w-[650px] h-28 bg-zinc-900 border border-zinc-700 rounded-md p-4 outline-none"></textarea>
        <button
        class="bg-blue-500 hover:bg-blue-600 px-6 py-3 rounded-md mt-3 font-medium">
            Create New Post
        </button>
    </form>

    <div class="mt-20">
        <h2 class="text-xl text-zinc-300 mb-6">
            Your Posts.
        </h2>
        <div class="space-y-5">
            <% user.posts.forEach(function(post){ %>
                <div class="w-[650px] bg-zinc-800 border border-zinc-700 rounded-md p-5">
                    <h3 class="text-blue-500 font-semibold mb-4">
                        @<%= user.username %>
                    </h3>
                    <p class="mb-4">
                        <%= post.content %>
                    </p>
                    <p class="text-sm mb-3">
                        <%= post.likes.length %> likes
                    </p>
                   <div class="flex gap-5">
                      <a href="/like/<%= post._id %>" class="text-blue-500 hover:text-blue-400">
                           <%= post.likes.indexOf(user._id) === -1 ? "Like" : "Unlike" %>
                      </a>
                       <a href="/edit/<%= post._id %>" class="text-gray-400 hover:text-gray-300">
                           Edit
                      </a>
                        <a href="/delete/<%= post._id %>" class="text-red-500 hover:text-red-400" onclick="return confirm('Are you sure you want to delete this post?')">
                            Delete
                        </a>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

</div>

</body>
</html>