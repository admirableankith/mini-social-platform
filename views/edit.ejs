<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>

    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-white min-h-screen">

<div class="p-10">

    <div class="flex justify-end">
        <a href="/logout"
        class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded-md">
            Logout
        </a>
    </div>

    <h2 class="text-xl mt-10 mb-5">
        Edit your post.
    </h2>

    <form action="/update/<%= post._id %>" method="POST">

        <textarea
        name="content"
        class="w-[650px] h-28 bg-zinc-900 border border-zinc-700 rounded-md p-4 outline-none"><%= post.content %></textarea>

        <button
        class="bg-yellow-400 hover:bg-yellow-500 text-black px-8 py-3 rounded-md mt-4 font-semibold">
            Update Post
        </button>

    </form>

</div>

</body>
</html>